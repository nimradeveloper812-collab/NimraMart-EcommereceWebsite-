@model List<ECommerceApp.Models.Product>
@{
    ViewData["Title"] = "Home";
}

<div class="hero-section fade-in-up">
    <div class="hero-visual"></div>
    <div class="row align-items-center">
        <div class="col-lg-7">
            <div class="hero-badge">
                <i class="bi bi-stars"></i> New Season Arrivals
            </div>
            <h1>Shop <span>Smarter</span>,<br>Live Better.</h1>
            <p class="lead">Premium products at unbeatable prices. Free delivery on orders over Rs. 2,000.</p>
            <div class="d-flex gap-3 flex-wrap">
                <a class="btn btn-gold btn-lg" asp-controller="Product" asp-action="Index">
                    <i class="bi bi-grid me-2"></i>Shop Now
                </a>
                <a class="btn btn-outline-dark btn-lg" asp-controller="Product" asp-action="Index" asp-route-sortBy="latest">
                    <i class="bi bi-clock me-2"></i>New Arrivals
                </a>
            </div>
            <div class="hero-stats">
                <div class="hero-stat-item">
                    <div class="stat-num">500+</div>
                    <div class="stat-lbl">Products</div>
                </div>
                <div class="hero-stat-item">
                    <div class="stat-num">10K+</div>
                    <div class="stat-lbl">Customers</div>
                </div>
                <div class="hero-stat-item">
                    <div class="stat-num">4.9★</div>
                    <div class="stat-lbl">Rating</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Categories Section -->
<div class="mb-5">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h3 class="section-title mb-1">Shop by Category</h3>
            <div class="title-divider"></div>
        </div>
    </div>
    <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-3">
        @foreach (var cat in ViewBag.Categories as List<ECommerceApp.Models.Category>)
        {
            <div class="col">
                <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@cat.Id"
                       class="text-decoration-none">
                    <div style="background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.5rem;text-align:center;transition:all 0.2s;"
                         onmouseover="this.style.borderColor='var(--gold)';this.style.transform='translateY(-3px)'"
                         onmouseout="this.style.borderColor='var(--border)';this.style.transform='translateY(0)'">
                        <i class="bi @(cat.IconClass ?? "bi-tag")" style="font-size:2rem;color:var(--gold);"></i>
                        <div style="font-weight:600;margin-top:0.5rem;color:var(--text);">@cat.Name</div>
                        <div style="font-size:0.78rem;color:var(--text-dim);">@cat.Products.Count items</div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h3 class="section-title mb-1">Featured Products</h3>
        <div class="title-divider"></div>
    </div>
    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-dark btn-sm">
        View All <i class="bi bi-arrow-right ms-1"></i>
    </a>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-icon"><i class="bi bi-box-seam"></i></div>
        <h5>No products yet</h5>
        <p>Check back soon for new arrivals.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-4">
        @foreach (var (p, i) in Model.Select((p, i) => (p, i)))
        {
            <div class="col fade-in-up fade-in-up-@(i % 4 + 1)">
                <div class="card h-100">
                    <div class="card-img-wrap">
                        <img src="@(string.IsNullOrEmpty(p.ImageUrl) ? "https://placehold.co/400x280/1e2333/c9a84c?text=No+Image" : p.ImageUrl)"
                             class="card-img-top" style="height:210px;object-fit:cover;" alt="@p.Name" />
                        <div class="img-overlay">
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@p.Id"
                                   class="btn btn-gold btn-sm">
                                <i class="bi bi-eye me-1"></i>Quick View
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <h6 class="card-title">@p.Name</h6>
                        <p class="price-tag">Rs. @p.Price.ToString("N0")</p>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@p.Id"
                           class="btn btn-outline-dark btn-sm flex-fill">
                            <i class="bi bi-eye me-1"></i>View
                        </a>
                        <form asp-controller="Cart" asp-action="Add" method="post" class="flex-fill">
                            <input type="hidden" name="productId" value="@p.Id" />
                            <input type="hidden" name="quantity" value="1" />
                            <button type="submit" class="btn btn-gold btn-sm w-100">
                                <i class="bi bi-cart-plus me-1"></i>Add
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
