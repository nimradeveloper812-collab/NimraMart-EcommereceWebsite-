@model ECommerceApp.Models.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="page-header">
    <div>
        <h3 class="section-title mb-1"><i class="bi bi-lock me-2"></i>Checkout</h3>
        <div class="title-divider"></div>
    </div>
</div>

<form asp-controller="Cart" asp-action="PlaceOrder" method="post" id="checkoutForm">
    @Html.AntiForgeryToken()
    <div class="row g-4">

        <div class="col-md-7">

            <div style="background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:2rem;margin-bottom:1.5rem;">
                <h5 class="checkout-section-title"><i class="bi bi-geo-alt me-2"></i>Shipping Information</h5>
                <div class="mb-3">
                    <label class="form-label">Full Shipping Address</label>
                    <textarea name="ShippingAddress" class="form-control" rows="3" required
                              placeholder="House #, Street, Area, City, Province">@Model.ShippingAddress</textarea>
                </div>
            </div>

            <div style="background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:2rem;">
                <h5 class="checkout-section-title"><i class="bi bi-credit-card me-2"></i>Payment Method</h5>

                <div class="d-flex gap-3 mb-4">

                    <div class="flex-fill" onclick="selectPayment('COD')" style="cursor:pointer;">
                        <div id="card-cod" style="border:2px solid var(--primary,#0d6efd);border-radius:12px;padding:1.2rem;text-align:center;background:var(--bg-1);transition:all .2s;">
                            <input type="radio" name="PaymentMethod" value="COD" id="radio-cod" checked style="display:none;" />
                            <i class="bi bi-cash-coin" style="font-size:2rem;color:var(--primary,#0d6efd);"></i>
                            <div style="font-weight:600;margin-top:.5rem;">Cash on Delivery</div>
                            <small style="color:var(--text-muted);">Pay when you receive</small>
                        </div>
                    </div>

                    <div class="flex-fill" onclick="selectPayment('Card')" style="cursor:pointer;">
                        <div id="card-card" style="border:2px solid var(--border);border-radius:12px;padding:1.2rem;text-align:center;background:var(--bg-1);transition:all .2s;">
                            <input type="radio" name="PaymentMethod" value="Card" id="radio-card" style="display:none;" />
                            <i class="bi bi-credit-card-2-front" style="font-size:2rem;color:var(--text-muted);"></i>
                            <div style="font-weight:600;margin-top:.5rem;">Debit / Credit Card</div>
                            <small style="color:var(--text-muted);">Secure card payment</small>
                        </div>
                    </div>

                </div>

                <div id="cardFields" style="display:none;">
                    <hr />
                    <div class="mb-3">
                        <label class="form-label">Card Holder Name</label>
                        <input type="text" name="CardHolderName" id="cardHolderName" class="form-control"
                               placeholder="As printed on card" autocomplete="cc-name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Card Number</label>
                        <input type="text" name="CardNumber" id="cardNumber" class="form-control"
                               placeholder="0000 0000 0000 0000"
                               maxlength="19" autocomplete="cc-number" oninput="formatCardNumber(this)" />

                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Expiry Date</label>
                            <input type="text" name="ExpiryDate" id="expiryDate" class="form-control"
                                   placeholder="MM / YY" maxlength="7" autocomplete="cc-exp" />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label">CVV</label>
                            <input type="password" name="CVV" id="cvv" class="form-control"
                                   placeholder="•••" maxlength="4" autocomplete="cc-csc" />
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2 mt-1" style="color:var(--text-muted);font-size:.82rem;">
                        <i class="bi bi-shield-lock-fill text-success"></i>
                        Your card details are never stored. Demo card pre-filled for testing.
                    </div>
                </div>

            </div>
        </div>

        <div class="col-md-5">
            <div class="cart-summary">
                <h5 class="checkout-section-title"><i class="bi bi-receipt me-2"></i>Order Summary</h5>
                @foreach (var item in Model.Cart.Items)
                {
                    <div class="d-flex justify-content-between mb-2 pb-2"
                         style="border-bottom:1px solid var(--border);font-size:.88rem;">
                        <span style="color:var(--text-muted);">
                            @item.ProductName
                            <span style="color:var(--text-dim);">× @item.Quantity</span>
                        </span>
                        <span style="color:var(--text);font-weight:500;">Rs. @item.Subtotal.ToString("N0")</span>
                    </div>
                }
                <div class="total-row d-flex justify-content-between">
                    <span>Total</span>
                    <span>Rs. @Model.Cart.Total.ToString("N0")</span>
                </div>
            </div>

            <button type="submit" class="btn btn-success btn-lg w-100 mt-3">
                <i class="bi bi-bag-check me-2"></i>Place Order
            </button>
            <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-dark w-100 mt-2">
                <i class="bi bi-arrow-left me-1"></i>Back to Cart
            </a>
        </div>

    </div>
</form>

@section Scripts {
    <script>
        function selectPayment(method) {
            const isCod = method === 'COD';

            document.getElementById('radio-cod').checked = isCod;
            document.getElementById('radio-card').checked = !isCod;

            document.getElementById('card-cod').style.borderColor = isCod ? 'var(--primary, #0d6efd)' : 'var(--border)';
            document.getElementById('card-card').style.borderColor = !isCod ? 'var(--primary, #0d6efd)' : 'var(--border)';

            const cardIcon = document.querySelector('#card-card i');
            cardIcon.style.color = !isCod ? 'var(--primary, #0d6efd)' : 'var(--text-muted)';

            document.getElementById('cardFields').style.display = isCod ? 'none' : 'block';

            document.querySelectorAll('#cardFields input').forEach(el => {
                el.required = !isCod;
            });
        }

        function formatCardNumber(input) {
            let v = input.value.replace(/\D/g, '').substring(0, 16);
            input.value = v.replace(/(.{4})/g, '$1 ').trim();
        }
    </script>
}