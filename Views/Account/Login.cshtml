@model ECommerceApp.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="auth-card">
            <div class="text-center mb-4">
                <i class="bi bi-bag-heart-fill" style="font-size:2.5rem;color:var(--gold);"></i>
                <h4 class="mt-2 mb-0">Welcome back</h4>
                <p class="auth-subtitle">Sign in to your NimraMart account</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mb-4">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@e.ErrorMessage</div>
                    }
                </div>
            }

            @* ── Continue with Google ──────────────────────────────────── *@
            <a asp-action="GoogleLogin"
                   asp-controller="Account"
                   class="btn btn-google w-100 mb-3 d-flex align-items-center justify-content-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48" aria-hidden="true">
                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                    <path fill="none" d="M0 0h48v48H0z" />
                </svg>
                Continue with Google
            </a>

            @* ── Divider ───────────────────────────────────────────────── *@
            <div class="auth-divider d-flex align-items-center my-3 gap-2">
                <hr class="flex-grow-1 m-0" style="border-color:var(--border);" />
                <span style="font-size:0.8rem;color:var(--text-muted);white-space:nowrap;">or sign in with email</span>
                <hr class="flex-grow-1 m-0" style="border-color:var(--border);" />
            </div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text" style="background:var(--bg-3);border-color:var(--border);color:var(--text-muted);">
                            <i class="bi bi-envelope"></i>
                        </span>
                        <input asp-for="Email" class="form-control" type="email" required placeholder="you@example.com" />
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-text" style="background:var(--bg-3);border-color:var(--border);color:var(--text-muted);">
                            <i class="bi bi-lock"></i>
                        </span>
                        <input asp-for="Password" class="form-control" type="password" required placeholder="••••••••" />
                    </div>
                </div>
                <button type="submit" class="btn btn-gold w-100 btn-lg">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </form>
            <p class="text-center mt-3 mb-0" style="font-size:0.9rem;color:var(--text-muted);">
                Don't have an account? <a asp-action="Register" style="color:var(--gold);">Register here</a>
            </p>
        </div>
    </div>
</div>

                    <style>
    .btn-google {
        background-color: #ffffff;
        color:            #3c4043;
        border:           1px solid #dadce0;
        font-weight:      500;
        font-size:        0.95rem;
        padding:          0.55rem 1rem;
        border-radius:    6px;
        transition:       background-color 0.15s ease, box-shadow 0.15s ease;
        text-decoration:  none;
    }
    .btn-google:hover {
        background-color: #f8f9fa;
        box-shadow:       0 1px 4px rgba(60,64,67,.25);
        color:            #3c4043;
        text-decoration:  none;
    }
    .btn-google:active  { background-color: #f1f3f4; }
    .btn-google:focus-visible {
        outline: 2px solid #4285F4;
        outline-offset: 2px;
    }
</style>