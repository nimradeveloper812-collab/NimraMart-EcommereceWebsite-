@model ECommerceApp.Models.User
@{
    ViewData["Title"] = "Profile";
    var initials = string.IsNullOrEmpty(Model?.FullName) ? "?" : string.Concat(Model.FullName.Split(' ').Where(w => w.Length > 0).Take(2).Select(w => w[0].ToString().ToUpper()));
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="profile-card fade-in-up">
            <div class="profile-header">
                <div class="profile-avatar">@initials</div>
                <div>
                    <h4 style="margin-bottom:0.2rem;">@Model?.FullName</h4>
                    <span class="badge bg-secondary">@Model?.Role</span>
                </div>
            </div>
            <div class="profile-body">
                <div class="profile-field">
                    <label><i class="bi bi-envelope me-1"></i>Email</label>
                    <span>@Model?.Email</span>
                </div>
                @if (!string.IsNullOrEmpty(Model?.Phone))
                {
                    <div class="profile-field">
                        <label><i class="bi bi-phone me-1"></i>Phone</label>
                        <span>@Model.Phone</span>
                    </div>
                }
                <div class="profile-field">
                    <label><i class="bi bi-calendar me-1"></i>Member Since</label>
                    <span>@(Model?.CreatedAt.ToString("MMMM dd, yyyy") ?? "—")</span>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <a asp-controller="Order" asp-action="Index" class="btn btn-gold">
                        <i class="bi bi-receipt me-1"></i>My Orders
                    </a>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-dark">
                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
