@model List<ECommerceApp.Models.Category>
@{
    ViewData["Title"] = "Manage Categories";
}

<div class="page-header">
    <div>
        <h3 class="section-title mb-1"><i class="bi bi-grid me-2"></i>Categories</h3>
        <div class="title-divider"></div>
    </div>
    <a asp-controller="Admin" asp-action="CreateCategory" class="btn btn-gold btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Add Category
    </a>
</div>

<div style="background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Icon</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Products</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td style="color:var(--text-dim);">@c.Id</td>
                        <td><i class="bi @(c.IconClass ?? "bi-tag") fs-5" style="color:var(--gold);"></i></td>
                        <td style="font-weight:500;">@c.Name</td>
                        <td style="color:var(--text-dim);font-size:0.85rem;">@c.Description</td>
                        <td><span class="badge bg-secondary">@c.Products.Count</span></td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-controller="Admin" asp-action="EditCategory" asp-route-id="@c.Id"
                                   class="btn btn-outline-dark btn-sm"><i class="bi bi-pencil"></i></a>
                                <form asp-controller="Admin" asp-action="DeleteCategory" method="post"
                                      onsubmit="return confirm('Delete this category?')">
                                    <input type="hidden" name="id" value="@c.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash3"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>